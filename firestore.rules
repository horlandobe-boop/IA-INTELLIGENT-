rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Configs
    match /configs/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Products
    match /products/{productId} {
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid)
      );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Broadcasts
    match /broadcasts/{broadcastId} {
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // Messenger Users (Clients)
    match /messenger_users/{docId} {
      allow read, write: if isSignedIn() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
  }
}
